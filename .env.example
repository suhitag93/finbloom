# finBloom — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# For production deployments (Netlify, Vercel, etc.) set these as
# platform environment variables — do NOT commit a filled .env file.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in your Supabase project dashboard under Settings > API

# The full project URL
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"

# The anon/public key — safe to expose in the browser
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ..."

# The project ref (subdomain portion of the URL above)
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# ── Analytics (optional) ──────────────────────────────────────────────────────
# Leave empty to disable PostHog analytics
VITE_POSTHOG_KEY=""
